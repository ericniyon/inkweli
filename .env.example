# Database
DATABASE_URL="postgresql://user:password@host:port/database"

# Email (password reset, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
APP_URL=http://localhost:3000

# UrubutoPay (server-side only; do not commit real keys)
# Base URL: staging = https://staging.urubutopay.rw, production = https://urubutopay.rw
URUBUTOPAY_BASE_URL=https://staging.urubutopay.rw
URUBUTOPAY_API_KEY_STAGING=upg:test_sk_6a74567bb7524b91f3f48b6973767df8:b17fc947abb9d59939453eab93a402d9
URUBUTOPAY_API_KEY_PRODUCTION=upg:live_sk_xxx
URUBUTOPAY_MERCHANT_CODE=TH13776003
# Service codes = slug after /pwl/ in your Payment Link URL. Used by API (initiate) and by membership direct link when NEXT_PUBLIC_* below are set.
URUBUTOPAY_SERVICE_CODE_ANNUAL=annual-package-1777494294743
URUBUTOPAY_SERVICE_CODE_PER_ARTICLE=per-article-package-1777494222439
# Optional: same values for client so /membership direct "Get started" link uses .env (set these to match above to use one source of truth)
NEXT_PUBLIC_URUBUTOPAY_BASE_URL=https://urubutopay.rw
NEXT_PUBLIC_URUBUTOPAY_SERVICE_CODE_ANNUAL=annual-package-1777494294743
NEXT_PUBLIC_URUBUTOPAY_SERVICE_CODE_PER_ARTICLE=per-article-package-1777494222439
# Webhook: If UrubutoPay portal lets you register an "Auth URL", set these and give UrubutoPay the same credentials.
# If the portal has no Auth URL field: leave these empty; we accept callbacks using your API key (same as above).
URUBUTOPAY_WEBHOOK_AUTH_USER=
URUBUTOPAY_WEBHOOK_AUTH_PASSWORD=
URUBUTOPAY_WEBHOOK_JWT_SECRET=
# Optional: verify callback signature (if UrubutoPay sends X-UrubutoPay-Signature)
URUBUTOPAY_WEBHOOK_SECRET_STAGING=
URUBUTOPAY_WEBHOOK_SECRET_PRODUCTION=
# Optional: pre-fill phone in payment dialog (testing only; leave empty in production)
NEXT_PUBLIC_URUBUTOPAY_TEST_PHONE=0788616703
# Optional: Gemini / AI
API_KEY=
GEMINI_MODEL=gemini-1.5-flash
NEXT_PUBLIC_GEMINI_API_KEY=

# NextAuth (if used)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
