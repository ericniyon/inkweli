# Database
DATABASE_URL="postgresql://user:password@host:port/database"

# Email (password reset, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Verified sender in Brevo (not your SMTP_USER @smtp-brevo.com). For Gmail/Yahoo deliveries, authenticate your domain in Brevo (SPF/DKIM/DMARC).
EMAIL_FROM=
# Optional display name shown in inbox
EMAIL_FROM_NAME=
# Optional: set to 1 for verbose SMTP wire logs locally
SMTP_DEBUG=
# Public site URL (production: https://www.usethinkup.com). Used for card return + success redirects. Defaults to https://VERCEL_URL on Vercel if unset.
APP_URL=http://localhost:3000

# UrubutoPay (server-side only; do not commit real keys)
# Base URL: staging = https://staging.urubutopay.rw, production = https://urubutopay.rw
# Live: https://urubutopay.rw — This also selects production API keys / webhook HMAC secrets alongside NODE_ENV.
URUBUTOPAY_BASE_URL=https://staging.urubutopay.rw
URUBUTOPAY_API_KEY_STAGING=upg:test_sk_6a74567bb7524b91f3f48b6973767df8:b17fc947abb9d59939453eab93a402d9
URUBUTOPAY_API_KEY_PRODUCTION=upg:live_sk_xxx
# Optional fallback: if you store one key here, webhook + payer-verify will match Authorization against it alongside *_STAGING/*_PRODUCTION
URUBUTOPAY_API_KEY=
# Optional legacy alias (same as URUBUTOPAY_API_KEY; read by lib/urubutopay)
URUBUTO_API_KEY=
URUBUTOPAY_MERCHANT_CODE=TH13776003
# Optional shorthand (fallback in lib/urubutopay): URUBUTO_MERCHANT_CODE=e.g.TH13614487
URUBUTO_MERCHANT_CODE=
# PWL slug = segment after /pwl/ (`paymentLinkId` on initiate). Used by `/membership` links when NEXT_PUBLIC_* match.
URUBUTOPAY_SERVICE_CODE_ANNUAL=annual-package-1777494294743
URUBUTOPAY_SERVICE_CODE_PER_ARTICLE=per-article-package-1777494222439
# Optional: gateway `service_code` field if Urubutu gives a separate id (e.g. subscription-xxxx). Omit to reuse PWL slug above.
URUBUTOPAY_INITIATE_SERVICE_CODE_ANNUAL=
URUBUTOPAY_INITIATE_SERVICE_CODE_PER_ARTICLE=subscription-9644
# Numeric portal IDs for initiate-link-payment (`payment_link_id`, `service_id`)
URUBUTOPAY_PAYMENT_LINK_ID_ANNUAL=
URUBUTOPAY_PAYMENT_LINK_ID_PER_ARTICLE=4300
URUBUTOPAY_SERVICE_ID_ANNUAL=
URUBUTOPAY_SERVICE_ID_PER_ARTICLE=9548
# Optional: same values for client so /membership direct "Get started" link uses .env (set these to match above to use one source of truth)
NEXT_PUBLIC_URUBUTOPAY_BASE_URL=https://urubutopay.rw
NEXT_PUBLIC_URUBUTOPAY_SERVICE_CODE_ANNUAL=annual-package-1777494294743
NEXT_PUBLIC_URUBUTOPAY_SERVICE_CODE_PER_ARTICLE=per-article-package-1777494222439
# Webhook auth URL (often same as site root POST /): portal POSTs user_name/password; we return a Bearer JWT UrubutoPay uses on validation + notification callbacks.
# Required when the portal expects token-based callbacks: set strong random JWT secret + credentials UrubutoPay portal is configured with.
URUBUTOPAY_WEBHOOK_AUTH_USER=
URUBUTOPAY_WEBHOOK_AUTH_PASSWORD=
URUBUTOPAY_WEBHOOK_JWT_SECRET=
# Optional: verify callback signature (if UrubutoPay sends X-UrubutoPay-Signature)
URUBUTOPAY_WEBHOOK_SECRET_STAGING=
URUBUTOPAY_WEBHOOK_SECRET_PRODUCTION=
# Extra raw webhook bodies in logs (truncate). Off by default — set to 1 to enable verbose JSON in server logs
URUBUTOPAY_DEBUG_LOGS=
# Optional: pre-fill phone in payment dialog (testing only; leave empty in production)
NEXT_PUBLIC_URUBUTOPAY_TEST_PHONE=0788616703
# Optional: Gemini / AI
API_KEY=
GEMINI_MODEL=gemini-1.5-flash
NEXT_PUBLIC_GEMINI_API_KEY=

# NextAuth (if used)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
